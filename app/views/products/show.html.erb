<h1><%= @product.name %></h1>

<% if @product.image.attached? %>
  <%= image_tag @product.image, width: 250 %>
<% end %>

<p>
  <strong>Description:</strong><br>
  <%= @product.description %>
</p>

<p>
  <strong>Category:</strong>
  <%= @product.category.name %>
</p>

<p>
  <strong>Price:</strong>
  $<%= @product.price %>
</p>

<p>
  <strong>Stock:</strong>
  <%= @product.stock_quantity %>
</p>

<p>
  <%= link_to "Back to Products", root_path %>
</p>